        a + b + c + d + e + f
        + g + h + i + j + k + l
        + m + n + o + p + q + r
        + s + t + u + v + w + x
        + y + z,
    mega52 = \a b c d e f g h i j k l m n o p q r s t u v w x y z aa ab ac ad ae af ag ah ai aj ak al am an ao ap aq ar as_ at au av aw ax ay az ->
        a + b + c + d + e + f
        + g + h + i + j + k + l
        + m + n + o + p + q + r
        + s + t + u + v + w + x
        + y + z + aa + ab + ac + ad
