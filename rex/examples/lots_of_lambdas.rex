let
    id = \x -> x,
    add = \x y -> x + y,
    sub = \x y -> x - y,
    mul = \x y -> x * y,
    inc = \x -> x + 1,
    dec = \x -> x - 1,
    square = \x -> x * x,
    cube = \x -> x * x * x,
    quad = \x -> x * x * x * x,
    clamp = \lo hi x -> if x < lo then lo else if x > hi then hi else x,
    is_even = \x -> x % 2 == 0,
    is_odd = \x -> x % 2 != 0,
    choose = \a b c d e f g h i j -> if a + b > c + d then e + f + g + h + i + j else a + b + c + d,
